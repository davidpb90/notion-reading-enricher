# Copy to .env and fill in values.

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Name of the URL-type column in your database (must match exactly).
NOTION_URL_PROPERTY=Link

# Comma-separated property names to never fill (e.g. manual Status or Relation).
NOTION_SKIP_PROPERTIES=

# Optional: PropertyName=hint;Other=hint
NOTION_PROPERTY_HINTS=

# --- LLM (OpenAI-compatible API: Ollama, Groq, OpenRouter, OpenAI, etc.)

LLM_MODEL=llama3.2
LLM_API_KEY=
# For Ollama locally, leave LLM_API_KEY empty and set:
LLM_BASE_URL=http://localhost:11434/v1

# Examples:
# Groq: LLM_BASE_URL=https://api.groq.com/openai/v1 LLM_API_KEY=gsk_...
# OpenAI: LLM_BASE_URL=https://api.openai.com/v1 LLM_API_KEY=sk-...

LLM_MAX_ARTICLE_CHARS=12000
LLM_TEMPERATURE=0.2

# Pause between Notion PATCH calls (seconds) to respect rate limits.
NOTION_SLEEP_SECONDS=0.35

# Optional: JSON database query filter (combined with --since via "and").
# Example single property: {"property":"Status","select":{"equals":"To enrich"}}
NOTION_QUERY_FILTER=
